{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/api-server run build && PORT=5173 BASE_PATH=/ pnpm --filter @workspace/novex-solutions run build",
  "outputDirectory": "artifacts/novex-solutions/dist/public",
  "builds": [
    {
      "src": "artifacts/api-server/dist/handler.mjs",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/artifacts/api-server/dist/handler.mjs"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
